generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  MANAGER
  STAFF
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum OrderChannel {
  MOBILE
  KIOSK
  POS
}

enum PaymentMethod {
  CASH
  CARD
  MIXED
  UNPAID
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
}

enum AdjustmentType {
  DISCOUNT
  REFUND
  VOID_ITEM
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum IceOptionType {
  BASE
  COATING
  FILLING
}

model User {
  id                 String            @id @default(cuid())
  name               String
  username           String            @unique
  password           String
  role               UserRole          @default(STAFF)
  isActive           Boolean           @default(true)
  createdOrders      Order[]           @relation("OrderCreatedBy")
  openedShifts       CashShift[]       @relation("ShiftOpenedBy")
  closedShifts       CashShift[]       @relation("ShiftClosedBy")
  orderAdjustments   OrderAdjustment[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

model Category {
  id              String     @id
  name            String
  emoji           String     @default("🍽️")
  sortOrder       Int        @default(0)
  accentColor     String     @default("#F26522")
  isIceCreamHub   Boolean    @default(false)
  showCustomBadge Boolean    @default(false)
  items           MenuItem[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  price       Int
  emoji       String   @default("🍽️")
  description String   @default("")
  tags        Json     @default("{}")
  modifiers   Json     @default("[]")
  imageUrl    String?
  isAvailable Boolean  @default(true)
  sortOrder   Int      @default(0)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
}

model IceCreamOption {
  id        String        @id
  type      IceOptionType
  name      String
  color     String        @default("#ffffff")
  texture   String?
  priceMod  Int           @default(0)
  emoji     String        @default("🍦")
  hotBoost  Float?
  coldBoost Float?
  isActive  Boolean       @default(true)
  sortOrder Int           @default(0)
  visualProfile Json?

  @@unique([type, id])
}

model PhoneOtp {
  id        String   @id @default(cuid())
  phone     String
  code      String
  purpose   String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone, purpose])
  @@index([expiresAt])
}

model Customer {
  id            String               @id @default(cuid())
  phone         String?              @unique
  name          String?
  isRegistered  Boolean              @default(false)
  preferences   Json                 @default("{}")
  chillPoints   Int                  @default(0)
  orders        Order[]
  loyaltyLedger LoyaltyTransaction[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([isRegistered])
}

model LoyaltyTransaction {
  id         String   @id @default(cuid())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String
  orderId    String?
  type       String
  points     Int
  meta       Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@index([createdAt])
}

model WaitGameSession {
  id           String    @id @default(cuid())
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String    @unique
  customerId   String?
  pointsEarned Int       @default(0)
  rounds       Json      @default("{}")
  createdAt    DateTime  @default(now())
  closedAt     DateTime?

  @@index([customerId])
}

model CashShift {
  id             String      @id @default(cuid())
  status         ShiftStatus @default(OPEN)
  openingCash    Int         @default(0)
  closingCash    Int?
  expectedCash   Int?
  difference     Int?
  notes          String?
  openedByUserId String
  openedBy       User        @relation("ShiftOpenedBy", fields: [openedByUserId], references: [id])
  closedByUserId String?
  closedBy       User?       @relation("ShiftClosedBy", fields: [closedByUserId], references: [id])
  orders         Order[]
  openedAt       DateTime    @default(now())
  closedAt       DateTime?

  @@index([status])
  @@index([openedAt])
}

model Order {
  id              String         @id @default(cuid())
  code            String         @unique
  status          OrderStatus    @default(PENDING)
  channel         OrderChannel   @default(MOBILE)
  customerName    String?
  customerPhone   String?
  note            String?
  subtotal        Int            @default(0)
  discountAmount  Int            @default(0)
  discountNote    String?
  total           Int            @default(0)
  paymentStatus   PaymentStatus  @default(UNPAID)
  paymentMethod   PaymentMethod  @default(UNPAID)
  paidAmount      Int            @default(0)
  changeAmount    Int            @default(0)
  receiptNumber   Int?
  customerId      String?
  customer        Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdByUserId String?
  createdBy       User?          @relation("OrderCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  shiftId         String?
  shift           CashShift?     @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  payments        OrderPayment[]
  adjustments     OrderAdjustment[]
  waitGame        WaitGameSession?
  paidAt          DateTime?
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([customerId])
  @@index([paymentStatus])
  @@index([shiftId])
  @@index([receiptNumber])
}

model OrderPayment {
  id        String        @id @default(cuid())
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  method    PaymentMethod
  amount    Int
  createdAt DateTime      @default(now())

  @@index([orderId])
}

model OrderAdjustment {
  id              String         @id @default(cuid())
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId         String
  type            AdjustmentType
  amount          Int
  itemId          String?
  reason          String?
  createdByUserId String
  createdBy       User           @relation(fields: [createdByUserId], references: [id])
  createdAt       DateTime       @default(now())

  @@index([orderId])
}

model OrderItem {
  id           String  @id @default(cuid())
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  menuItemId   String?
  name         String
  emoji        String  @default("🍦")
  unitPrice    Int
  quantity     Int
  lineTotal    Int
  customConfig Json?

  @@index([orderId])
}

model Setting {
  key   String @id
  value Json
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String
  payload   Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

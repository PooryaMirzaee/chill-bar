# ── Database ──
POSTGRES_USER=chillbar
POSTGRES_PASSWORD=chillbar
POSTGRES_DB=chillbar
DATABASE_URL=postgresql://chillbar:chillbar@localhost:5432/chillbar?schema=public

# ── API ──
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
JWT_SECRET=change-me-to-a-long-random-secret
# Development (local Vite):
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# Docker / IP only:
# CORS_ORIGINS=http://YOUR_SERVER_IP:8080,http://YOUR_SERVER_IP:8081
# Production with domain + HTTPS:
CORS_ORIGINS=https://chill-bar.ir,https://www.chill-bar.ir,https://admin.chill-bar.ir

# ── Seed admin (first run) ──
SEED_ADMIN_USER=admin
SEED_ADMIN_PASSWORD=chillbar123

# ── AvalAI (optional server fallback — prefer admin panel) ──
AVALAI_API_KEY=

# ── SMS.ir (optional server fallback — prefer admin panel) ──
SMS_IR_API_KEY=
# In development only: log OTP to console instead of sending SMS
SMS_DEV_BYPASS=0

# ── Frontend (build-time) ──
# Leave empty in Docker production — nginx proxies /api/ on the same domain
VITE_API_URL=
